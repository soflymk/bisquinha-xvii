# Segredo para assinar as sessões de usuário (use uma string longa e aleatória em produção)
SESSION_SECRET="mude-isso-em-producao-use-algo-longo-e-aleatorio"

# Porta do servidor (Render injeta automaticamente via variável PORT)
PORT=3000

# Ambiente (development | production)
NODE_ENV=development

# Caminho do banco de dados SQLite (opcional, padrão: ./bisca.db)
# DB_PATH=/data/bisca.db
